  "glossary": [
    {
      "id": "engagement_score",
      "term": "Engagement Score",
      "definition": "A numeric score (0–100) representing the overall level of employee motivation and connection to the company."
    },
    {
      "id": "enps",
      "term": "eNPS",
      "definition": "Employee Net Promoter Score. Measures how likely employees are to recommend the company as a place to work. Range: -100 to +100."
    },
    {
      "id": "anonymity",
      "term": "Anonymity",
      "definition": "Individual responses are hidden when participation is below the anonymity threshold (default: 5 respondents). This protects employee privacy."
    },
    {
      "id": "pulse",
      "term": "Pulse Survey",
      "definition": "A short, frequent survey (typically 1–5 questions) used to track employee sentiment in real-time."
    }
  ],
